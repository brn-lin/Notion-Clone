{
  "compilerOptions": {
    /* JavaScript version */
    "target": "ES2022",

    /* Node.js ESM system */
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    /* Output */
    "outDir": "./dist",

    /* Type checking (strict mode ON) */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    /* Node types */
    "types": ["node"],

    /* Import behavior */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "verbatimModuleSyntax": true,

    /* Quality of life */
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    /* Module behavior */
    "moduleDetection": "force",

    /* Debugging */
    "sourceMap": true
  }
}
